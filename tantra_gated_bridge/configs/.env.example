# ===========================================
# TANTRA Gated Bridge - Global Environment
# ===========================================
# Copy this to .env and customize.

# Core Service
CORE_PORT=3000
CORE_SARATHI_URL=http://sarathi:3001
CORE_BRIDGE_URL=http://bridge:3002

# Sarathi Authority
SARATHI_PORT=3001
SARATHI_ISSUER=tantra-sarathi
# Optional: provide your own RSA key pair (PEM format)
# PRIVATE_KEY=...
# PUBLIC_KEY=...
JWT_EXPIRY=1h
JWT_EXPIRY_MS=3600000

# Bridge Service
BRIDGE_PORT=3002
BRIDGE_SARATHI_URL=http://sarathi:3001
BRIDGE_EXECUTION_URL=http://execution:3003

# Execution Service
EXECUTION_PORT=3003
EXECUTION_SARATHI_URL=http://sarathi:3001
EXECUTION_BUCKET_URL=http://bucket:3004

# Bucket Service
BUCKET_PORT=3004

# Replay Persistence
REPLAY_STORAGE_DIR=/app/data

# Docker Compose project name
COMPOSE_PROJECT_NAME=tantra-gated-bridge
