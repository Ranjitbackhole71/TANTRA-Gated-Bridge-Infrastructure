      "parameters": {
        "promptType": "define",
        "text": "=You are an AI assistant for Prophetic Business Solutions.\n\nExtract quotation details from the email.\n\nCRITICAL INSTRUCTIONS:\n\n1. Identify ALL services requested in the email.\n2. Return EVERY recognized service.\n3. Do NOT combine multiple services into one string.\n4. Return the services as a JSON array.\n5. Preserve the order in which they appear.\n\nReturn ONLY valid JSON.\n\n{\n  \"customer_name\": \"\",\n  \"company\": \"\",\n  \"services\": [],\n  \"turnover\": \"\",\n  \"requirements\": \"\"\n}\n\nExample:\n\n{\n  \"customer_name\": \"Akash Mehta\",\n  \"company\": \"TechNova Solutions Pvt Ltd\",\n  \"services\": [\n    \"CFO Services\",\n    \"GST Return Regular\",\n    \"ROC\"\n  ],\n  \"turnover\": \"12 Crore\",\n  \"requirements\": \"\"\n}\n\nEmail:\n{{ $('Gmail Trigger').item.json.textPlain || $('Gmail Trigger').item.json.snippet }}",
        "hasOutputParser": true,
