        "actionsUi": {
          "actionFields": [
            {
              "action": "insert",
              "text": "={{\n\"PROPHECTIC BUSINESS SOLUTIONS\\n\" +\n\"B Wing 1307, Kailas Business Park\\n\" +\n\"Veer Savarkar Marg, Park Site\\n\" +\n\"Vikhroli West - 400079\\n\" +\n\"Phone: +91 9167200152\\n\" +\n\"Email: vishal@prophetic.co.in\\n\" +\n\"Website: propheticbusinesssolutions.com\\n\\n\" +\n\n\"============================================================\\n\" +\n\"                     QUOTATION\\n\" +\n\"============================================================\\n\\n\" +\n\n\"Quotation No : \" + $json.quote_number + \"\\n\" +\n\"Date          : \" + $json.quotation_date + \"\\n\" +\n\"Valid Until   : 15 Days from Issue Date\\n\\n\" +\n\n\"------------------------------------------------------------\\n\" +\n\"CUSTOMER DETAILS\\n\" +\n\"------------------------------------------------------------\\n\" +\n\n\"Customer Name : \" + $json.customer_name + \"\\n\" +\n\"Company       : \" + $json.company + \"\\n\\n\" +\n\n\"------------------------------------------------------------\\n\" +\n\"SERVICE DETAILS\\n\" +\n\"------------------------------------------------------------\\n\\n\" +\n\n\"Service        : \" + $json.service + \"\\n\" +\n\"Service Code   : \" + $json.service_code + \"\\n\" +\n\"Frequency      : \" + $json.frequency + \"\\n\" +\n\"Turnover       : \" + $json.turnover + \"\\n\" +\n\"Amount         : ₹\" + $json.price + \"\\n\\n\" +\n\n\"------------------------------------------------------------\\n\" +\n\n\"Subtotal       : ₹\" + $json.price + \"\\n\" +\n\"GST            : Extra as Applicable\\n\" +\n\"Grand Total    : ₹\" + $json.price + \" + GST\\n\\n\" +\n\n\"------------------------------------------------------------\\n\" +\n\"TERMS & CONDITIONS\\n\" +\n\"------------------------------------------------------------\\n\" +\n\n\"• Quotation is valid for 15 days.\\n\" +\n\"• GST will be charged as applicable.\\n\" +\n\"• Payment Terms: Net 15 Days.\\n\" +\n\"• Work will commence after receipt of confirmation.\\n\" +\n\"• Any additional scope will be charged separately.\\n\\n\" +\n\n\"Thank you for giving us the opportunity to serve you.\\n\\n\" +\n\n\"For Prophetic Business Solutions\\n\\n\\n\" +\n\n\"______________________________\\n\" +\n\"Authorized Signatory\"\n}}"
            }
          ]
        }
