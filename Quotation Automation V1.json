    {
      "parameters": {
        "jsCode": "const rows = $input.all();\n\nconst aiOutput = JSON.parse($(\"AI Agent\").first().json.output);\nconst turnoverText = aiOutput.turnover;\n\n// Convert turnover text like \"3 Crore\" to a number\nfunction convertTurnover(text) {\n  const value = parseFloat(text);\n\n  if (text.toLowerCase().includes(\"crore\")) {\n    return value * 10000000;\n  }\n\n  if (text.toLowerCase().includes(\"lakh\")) {\n    return value * 100000;\n  }\n\n  return value;\n}\n\nconst turnover = convertTurnover(turnoverText);\n\nlet selected = null;\n\nfor (const row of rows) {\n  const range = row.json.col_5;\n\n  // Handle \"Above 50 cr\"\n  if (range.toLowerCase().includes(\"above\")) {\n    const limit = parseFloat(range.match(/\\d+/)[0]) * 10000000;\n    if (turnover > limit) {\n      selected = row.json;\n      break;\n    }\n  }\n\n  // Handle ranges like 10000000-100000000\n  else if (range.includes(\"-\")) {\n    const parts = range.split(\"-\");\n    const min = Number(parts[0]);\n    const max = Number(parts[1]);\n\n    if (turnover >= min && turnover <= max) {\n      selected = row.json;\n      break;\n    }\n  }\n}\n\nif (!selected) {\n  throw new Error(\"No matching price found for turnover.\");\n}\n\nreturn [\n  {\n    json: {\n      customer_name: aiOutput.customer_name,\n      company: aiOutput.company,\n      service: aiOutput.service,\n      turnover: aiOutput.turnover,\n      price: selected.col_6,\n      frequency: selected.col_7,\n      service_code: selected.col_3\n    }\n  }\n];"
      },
