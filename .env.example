# AIAIC Platform Runtime - Environment Template
# Copy to .env and customize

# === Platform Runtime ===
AIAIC_ENV=development
AIAIC_PORT=8000
AIAIC_HOST=0.0.0.0
AIAIC_WORKERS=2
AIAIC_DEBUG=false
AIAIC_LOG_LEVEL=INFO
AIAIC_METRICS_ENABLED=true
AIAIC_HEALTH_CHECK_INTERVAL=30

# === Redis ===
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# === TANTRA Core Service ===
TANTRA_CORE_PORT=3000
SARATHI_URL=http://localhost:3001
BRIDGE_URL=http://localhost:3002

# === TANTRA Sarathi Authority ===
TANTRA_SARATHI_PORT=3001
ISSUER=tantra-sarathi
JWT_EXPIRY=1h
JWT_EXPIRY_MS=3600000
# Uncomment to use persistent keys (auto-generated if not set):
# PRIVATE_KEY=...
# PUBLIC_KEY=...
SARATHI_KEY_DIR=./sarathi/keys

# === TANTRA Bridge Service ===
TANTRA_BRIDGE_PORT=3002
EXECUTION_URL=http://localhost:3003

# === TANTRA Execution Service ===
TANTRA_EXECUTION_PORT=3003
BUCKET_URL=http://localhost:3004
EXECUTION_OUTPUT_DIR=./execution/outputs

# === TANTRA Bucket Service ===
TANTRA_BUCKET_PORT=3004

# === Replay Persistence ===
REPLAY_STORAGE_DIR=./replay_persistence/data

# === InsightFlow (optional) ===
INSIGHTFLOW_URL=
INSIGHTFLOW_API_KEY=
INSIGHTFLOW_ENABLED=false

# === Gateway Service ===
AIAIC_GATEWAY_PORT=8000

# === Security ===
JWT_SECRET=your-secret-key-here
JWT_ALGORITHM=HS256
